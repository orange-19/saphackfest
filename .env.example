# ==============================================================================
# .env.example — copy to .env and fill in your values
# ==============================================================================

# --- PostgreSQL ---
# asyncpg connection string (note: postgresql+asyncpg:// not postgresql://)
DATABASE_URL=postgresql+asyncpg://governance:governance@localhost:5432/governance_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM Provider: "gemini" (default) or "groq" ---
LLM_PROVIDER=gemini

# Google Gemini 2.0 Flash Lite (free tier — https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-google-ai-studio-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# Groq Llama 3 8B (optional alternative — https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama3-8b-8192

# --- Governance Static Rules ---
MAX_DISCOUNT_PCT=20.0        # auto-reject if discount > 20%
MAX_PRICE_INCREASE_PCT=50.0  # auto-reject if increase > 50%
MIN_ABSOLUTE_PRICE=0.50      # auto-reject if proposed price < $0.50

# --- LLM Routing Thresholds ---
AI_HIGH_RISK_THRESHOLD=0.60    # escalate to HITL if confidence < 0.60
AI_AUTO_APPROVE_THRESHOLD=0.85 # auto-approve if confidence >= 0.85

# --- App Settings ---
DEBUG=false
CORS_ORIGINS=["*"]
